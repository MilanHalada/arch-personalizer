#!/usr/bin/env bash
set -euo pipefail

if command -v impala >/dev/null 2>&1; then
  exec foot --app-id wifi-menu bash -lc 'impala'
fi

if command -v wlctl >/dev/null 2>&1; then
  exec foot --app-id wifi-menu bash -lc 'wlctl'
fi

if command -v gazelle >/dev/null 2>&1; then
  exec foot --app-id wifi-menu bash -lc 'gazelle'
fi

exec foot --app-id wifi-menu bash -lc 'nmtui'
